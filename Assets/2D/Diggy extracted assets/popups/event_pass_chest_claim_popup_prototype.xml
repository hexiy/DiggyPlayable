<element name="event_pass_chest_reward_screen_holder" anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1" visible="true"  mouseUp="chestBackMouseUp_handler">
    <element name="black_screen" skin="@dark_shade_black" anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1" mouseUp="chestBackMouseUp_handler"/>
    <element name="popup_body" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER">
    <!-- light shine animation -->
    <element name="chest_reward_lightshine" skin="@claim_reward_shine_big" preferredWidth="700" preferredHeight="700" anchorAlign="MIDDLE_CENTER" flushBatch="true" pivotAlign="MIDDLE_CENTER" mouseUp="chestBackMouseUp_handler"/>
    <element name="chest_reward_item_lightshine" skin="@claim_reward_shine" visible="false" preferredWidth="500" preferredHeight="500" anchorAlign="MIDDLE_CENTER" flushBatch="true" pivotAlign="MIDDLE_CENTER" mouseUp="chestBackMouseUp_handler"/>

    <!-- spine animation -->
    <element name="spine_holder" skin="@asset" flushBatch="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="100" mouseUp="chestBackMouseUp_handler" />

    <!-- reward holder -->
    <element name="event_pass_reward_holder" flushBatch="true" visible="true" pivotAlign="MIDDLE_CENTER" anchorAlign="MIDDLE_CENTER" >

        <element name="event_pass_reward_item" pivotAlign="MIDDLE_CENTER" anchorAlign="MIDDLE_CENTER" preferredWidth="280" preferredHeight="500" >
            <element name="rewardImage" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"/>

            <element name="recurrent_reward_item_usable_holder" visible="false" visible.usable="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <element name="recurrent_reward_item_usable" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="region_badge_holder" visible="false"
                         pivotAlign="TOP_CENTER" anchorAlign="TOP_CENTER" anchorY="-5" anchorX="50" preferredWidth="50" preferredHeight="50">
                    <element name="region_badge"
                             skin.region1="@small_region_badge_1"
                             skin.region2="@small_region_badge_2"
                             skin.region3="@small_region_badge_3"
                             skin.region4="@small_region_badge_4"
                             skin.region5="@small_region_badge_5"
                             skin.region6="@small_region_badge_6"
                             skin.region7="@small_region_badge_7"
                             skin.region8="@small_region_badge_8"
                             skin.region9="@small_region_badge_9"
                             anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1" flushBatch="true"/>
                </element>
                <element name="recurrent_reward_item_usable_amount_shadow" skin="@eventpass_milestone_font_shadow" preferredHeight="80" anchorX="2" anchorY="32" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_usable_amount" skin="@eventpass_milestone_font" preferredHeight="80" anchorY="30" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredWidth="300" flushBatch="true" model="amount"/>
                <element name="recurrent_reward_item_usable_energy_icon" skin="@ico_energy" preferredWidth="58" anchorY="20" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorX="38" preferredHeight="70"/>
            </element>

            <element name="recurrent_reward_item_building_holder" visible="false" visible.building="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <!-- BUILDING GRIDS -->
                <element name="grids_holder">
                    <element name="grid2" anchorY="0" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER">
                        <p:layout><horizontal gap="-23"/></p:layout>
                        <element skin="@shop_equip_ph2"/>
                        <element skin="@shop_equip_ph2"/>
                        <element skin="@shop_equip_ph2"/>
                        <element skin="@shop_equip_ph2"/>
                    </element>
                    <element name="grid3" anchorY="0" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER">
                        <p:layout><horizontal gap="-19"/></p:layout>
                        <element skin="@shop_equip_ph3"/>
                        <element skin="@shop_equip_ph3"/>
                        <element skin="@shop_equip_ph3"/>
                        <element skin="@shop_equip_ph3"/>
                    </element>
                    <element name="grid4" anchorY="0" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER">
                        <p:layout><horizontal gap="-20"/></p:layout>
                        <element skin="@shop_equip_ph4"/>
                        <element skin="@shop_equip_ph4"/>
                        <element skin="@shop_equip_ph4"/>
                        <element skin="@shop_equip_ph4"/>
                    </element>
                </element>

                <element name="region_badge_holder" visible="false"
                         pivotAlign="TOP_CENTER" anchorAlign="TOP_CENTER" anchorY="-5" anchorX="50" preferredWidth="50" preferredHeight="50">
                    <element name="region_badge"
                             skin.region1="@small_region_badge_1"
                             skin.region2="@small_region_badge_2"
                             skin.region3="@small_region_badge_3"
                             skin.region4="@small_region_badge_4"
                             skin.region5="@small_region_badge_5"
                             skin.region6="@small_region_badge_6"
                             skin.region7="@small_region_badge_7"
                             skin.region8="@small_region_badge_8"
                             skin.region9="@small_region_badge_9"
                             anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1" flushBatch="true"/>
                </element>
                <element name="recurrent_reward_item_building" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="recurrent_reward_item_building_amount_shadow" skin="@eventpass_milestone_font_shadow" preferredHeight="80" anchorY="32" anchorX="2" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_building_amount" skin="@eventpass_milestone_font" preferredHeight="80" anchorY="30" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_building_energy_icon" visible="false" visible.energy="true"  preferredWidth="107" anchorY="35" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorX="67" preferredHeight="55">
                    <element skin="@hud_regen" anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1"/>
                </element>
                <element name="recurrent_reward_item_building_storage_icon" visible="false" visible.storage="true" preferredWidth="107" anchorY="40" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorX="67" preferredHeight="45">
                    <element skin="@hud_storage" anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1"/>
                </element>
            </element>

            <element name="recurrent_reward_item_material_holder" visible="false" visible.material="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <element name="recurrent_reward_item_material" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="recurrent_reward_item_material_amount_shadow" skin="@eventpass_milestone_font_shadow" preferredHeight="100" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="32" anchorX="2" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_material_amount" skin="@eventpass_milestone_font" preferredHeight="100" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="30" preferredWidth="300" flushBatch="true"/>
            </element>

            <element name="recurrent_reward_item_token_holder" visible="false" visible.token="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <element name="recurrent_reward_item_token" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="recurrent_reward_item_token_amount_shadow" skin="@eventpass_milestone_font_shadow" preferredHeight="80" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="32" anchorX="2" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_token_amount" skin="@eventpass_milestone_font" preferredHeight="80" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="30" preferredWidth="300" flushBatch="true"/>
            </element>

            <element name="recurrent_reward_item_diggy_skin_holder" visible="false" visible.diggy_skin="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <element name="recurrent_reward_item_diggy_skin" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="recurrent_reward_item_diggy_skin_name_shadow" skin="@eventpass_item_smaller_font_shadow" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredHeight="160" anchorY="-198" anchorX="2" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_diggy_skin_name" skin="@eventpass_item_smaller_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" preferredHeight="160" anchorY="-200" preferredWidth="300" flushBatch="true"/>
            </element>

            <element name="recurrent_reward_item_system_holder" visible="false" visible.system="true" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true">
                <element name="recurrent_reward_item_system" skin="@asset" preferredHeight="150" preferredWidth="128" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
                <element name="recurrent_reward_item_system_amount_shadow" skin="@eventpass_milestone_font_shadow" preferredHeight="80" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="32" anchorX="2" preferredWidth="300" flushBatch="true"/>
                <element name="recurrent_reward_item_system_amount" skin="@eventpass_milestone_font" preferredHeight="80" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="30" preferredWidth="300" flushBatch="true"/>
            </element>

        </element>

    </element>

    <!-- tap to collect text -->
    <element name="event_pass_collect_text" skin="@eventpass_hint_header_font" preferredWidth="600" preferredHeight="150" pivotAlign="MIDDLE_CENTER" anchorAlign="MIDDLE_CENTER" anchorY="520" flushBatch="true" model="#GUI3424"  mouseUp="chestBackMouseUp_handler"/>
    </element>
</element>