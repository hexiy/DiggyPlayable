<element name="black_screen" skin="@black" anchorTop="0" anchorBottom="1" mouseUp="backMouseUp_handler">
    <element name="popup_body" skin="@middle_popup_half" preferredWidth="880" preferredHeight="1000" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER">
        <element name="text" skin="@shop_item_name_font" preferredWidth="820" preferredHeight="300" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="100"/>

        <element anchorY="200" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
            <p:layout><vertical useChildrenWidth="true" gap="20"/></p:layout>
            <element name="usable" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
                <p:layout><horizontal gap="5"/></p:layout>
                <element name="usableAmount" anchorY="15" skin="@oswald_bold_85" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"/>
                <element name="usableAsset" skin="@asset" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" flushBatch="true"/>
            </element>
            <element name="energy" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
                <p:layout><horizontal gap="5"/></p:layout>
                <element name="energyText" anchorY="15" skin="@oswald_bold_85"/>
                <element name="energyAsset" skin="@asset"/>
                <element name="energyValue" anchorY="15" skin="@oswald_bold_85"/>
            </element>
        </element>

        <element name="region_badge_holder" visible="false"
                 pivotAlign="TOP_CENTER" anchorAlign="TOP_CENTER" anchorLeft=".5" anchorRight=".5">
            <element name="region_badge"
                     skin.region1="@region_badge_1"
                     skin.region2="@region_badge_2"
                     skin.region3="@region_badge_3"
                     skin.region4="@region_badge_4"
                     skin.region5="@region_badge_5"
                     skin.region6="@region_badge_6"
                     skin.region7="@region_badge_7"
                     skin.region8="@region_badge_8"
                     skin.region9="@region_badge_9"
                     anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1"/>
        </element>


        <element name="btn_ok" skin="@btn_center1" skin.pressed="@btn_center2" anchorY="-200" anchorAlign="BOTTOM_CENTER" pivotAlign="BOTTOM_CENTER">
            <element name="btn_ok_text" skin="@oswald_bold_85_basic_drevo1" anchorY="8" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"
                     flushBatch="true"/>
        </element>

        <element name="btn_cancel" skin="@btn_center1" skin.pressed="@btn_center2" anchorY="-70" anchorAlign="BOTTOM_CENTER" pivotAlign="BOTTOM_CENTER">
            <element name="btn_cancel_text" skin="@oswald_bold_85_basic_drevo1" anchorY="8" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"
                     flushBatch="true"/>
        </element>
    </element>
</element>