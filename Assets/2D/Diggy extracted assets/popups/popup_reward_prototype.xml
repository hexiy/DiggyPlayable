    <element name="rewardAmount" visible="true" visible.rewardText="false" skin="@popup_small_brown_reward" skin.amount_brown="@oswald_bold_42_align_center_bottom" skin.amount_white="@typeface_43_white_center_bottom" color.doubled="0x00FF00" visible.building="false"
