    <element name="rewardImage" skin="@asset" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="20"/>

    <!-- ONLY IN MINE FINISHED REWARD (IT HAS NAME OF REWARD!) -->
    <element name="rewardText" skin="@popup_small_brown" visible="false" visible.rewardText="true"
             anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="145"/>
    <!-- ONLY IN MINE FINISHED REWARD (IT HAS NAME OF REWARD!) -->

