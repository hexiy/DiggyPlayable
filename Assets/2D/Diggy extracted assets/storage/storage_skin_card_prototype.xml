				 preferredWidth.notselected="390" preferredHeight.notselected="100"/>

		<!-- TESTER LABEL SKIN ID -->
		<element name="testerLabel" skin="@shop_extras_tester_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER"
