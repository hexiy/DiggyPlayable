<element skin="@middle_popup" skin.pixel="@middle_popup_blue" preferredWidth="530" preferredHeight="956">
	<element anchorX="-20" preferredWidth="530" preferredHeight="926">
		<element name="name" skin="@shop_item_name_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER"
				 anchorY="20" preferredWidth="300" preferredHeight="200" anchorX="0" anchorX.regionBadgeVisible="20"/>

		<!-- SPECIAL WEEK DISCOUNT BADGE -->
		<element name="special_week_offer_discount" anchorAlign="TOP_RIGHT" pivotAlign="TOP_RIGHT" anchorY="60"
				 skin="@special_week_discount_30" visible="false"/>

		<!-- EVENT BADGE -->
		<element name="event_new_badge" anchorX="25" anchorY="70">
			<element skin="@shop_event_bg"/>
			<element name="new_badge_asset" skin="@shop_new"/>
			<element name="event_badge_asset" skin="@asset"/>
		</element>

		<element name="info_wrapper" anchorY="50" preferredWidth="530">
			<!-- BUILDING GRIDS -->
			<element name="grid2" anchorY="350" pivotAlign="BOTTOM_CENTER" anchorLeft=".5" anchorRight=".5">
				<p:layout><horizontal gap="-23"/></p:layout>
				<element skin="@shop_equip_ph2"/>
				<element skin="@shop_equip_ph2"/>
				<element skin="@shop_equip_ph2"/>
				<element skin="@shop_equip_ph2"/>
			</element>
			<element name="grid3" anchorY="350" pivotAlign="BOTTOM_CENTER" anchorLeft=".5" anchorRight=".5">
				<p:layout><horizontal gap="-19"/></p:layout>
				<element skin="@shop_equip_ph3"/>
				<element skin="@shop_equip_ph3"/>
				<element skin="@shop_equip_ph3"/>
				<element skin="@shop_equip_ph3"/>
			</element>
			<element name="grid4" anchorY="350" pivotAlign="BOTTOM_CENTER" anchorLeft=".5" anchorRight=".5">
				<p:layout><horizontal gap="-20"/></p:layout>
				<element skin="@shop_equip_ph4"/>
				<element skin="@shop_equip_ph4"/>
				<element skin="@shop_equip_ph4"/>
				<element skin="@shop_equip_ph4"/>
			</element>

			<!-- IMAGE -->
			<element name="image" anchorLeft=".5" anchorRight=".5" anchorY="345" skin="@asset" pivotAlign="BOTTOM_CENTER" flushBatch="true"/>
			<element name="limitRegion" skin="@shop_card_region_event" anchorAlign="TOP_RIGHT" pivotAlign="TOP_RIGHT" anchorY="260"><element anchorY="10" name="limitRegionImage" skin="@asset"/></element>

			<element name="region_badge_holder" visible="false"
					 pivotAlign="BOTTOM_CENTER" anchorAlign="BOTTOM_CENTER" anchorY="350">
				<element name="region_badge" skin.region1="@region_badge_1" skin.region2="@region_badge_2" skin.region3="@region_badge_3"
						 skin.region4="@region_badge_4"
						 skin.region5="@region_badge_5"
						 skin.region6="@region_badge_6"
						 skin.region7="@region_badge_7"
						 skin.region8="@region_badge_8"
						 skin.region9="@region_badge_9"
						 anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1"/>
			</element>

			<!-- VALUE -->
			<element skin="@shop_parameter_limit" anchorY="372" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
				<element anchorY="27" anchorX="-45" preferredWidth="200" preferredHeight="100" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="10"/></p:layout>
					<element name="type" skin.regen="@hud_regen" skin.storage="@hud_storage" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-10"/>
					<element name="value" skin="@shop_energy_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"/>
				</element>
				<element anchorY="38" anchorX="160" preferredWidth="50" preferredHeight="50" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<element name="limitAmountValue" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" skin="@shop_limit_font"/>
					<element name="limitAmountNone" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" skin="@shop_no_limit" anchorY="-5"/>
				</element>
			</element>

			<!-- COST -->
			<element name="price" anchorX="185">
				<element name="price1">
					<p:layout><horizontal gap="5"/></p:layout>
					<element name="priceImage1" skin="@asset"/>
					<element name="priceValue1" anchorY="15" skin="@shop_price_font"/>
					<element name="priceHave1" anchorY="15" skin="@shop_price_have_font"/>
				</element>
				<element name="price2">
					<p:layout><horizontal gap="5"/></p:layout>
					<element name="priceImage2" skin="@asset"/>
					<element name="priceValue2" anchorY="15" skin="@shop_price_font"/>
					<element name="priceHave2" anchorY="15" skin="@shop_price_have_font"/>
				</element>
				<element name="price3">
					<p:layout><horizontal gap="5"/></p:layout>
					<element name="priceImage3" skin="@asset"/>
					<element name="priceValue3" anchorY="15" skin="@shop_price_font"/>
					<element name="priceHave3" anchorY="15" skin="@shop_price_have_font"/>
				</element>
			</element>

			<!-- GEM COST -->
			<element name="gemPrice" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="515">
				<p:layout><horizontal gap="5"/></p:layout>
				<element name="gemImage" skin="@asset"/>
				<element name="gemValue" anchorY="15" skin="@shop_price_font"/>
			</element>

			<!-- LOCK -->
			<element name="lock" anchorLeft="0" anchorRight="1">
				<element skin="@shop_card_locked" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="570"/>
				<element name="lockText" skin="@shop_lock_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="500" preferredWidth="450" preferredHeight="400"/>
			</element>

		</element>

		<!-- LIMIT REACHED -->
		<element name="limitReached" anchorAlign="BOTTOM_CENTER" pivotAlign="BOTTOM_CENTER" anchorY="-30" skin="@shop_limit_reached">
			<element name="limitText" skin="@shop_price_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="-80"/>
		</element>

		<!-- BUTTON -->
		<element name="button" skin="@invisible" mouseChildren="false" preferredWidth="440" preferredHeight="142" anchorAlign="BOTTOM_CENTER" pivotAlign="BOTTOM_CENTER" anchorY="-30" mouseOut="buildingBuyOut_handler" mouseUp="buildingBuyUp_handler" mouseDown="buildingBuyDown_handler">

			<element anchorY="0" visible.basic-pixelcoin-inactive="false" visible.gem="true" skin="@button_green_01" skin.down="@button_green_02" preferredWidth="440" preferredHeight="142">
				<element anchorX="-10" anchorY="30" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="10"/></p:layout>
					<element skin="@shop_gem_icon1" skin.down="@shop_gem_icon2" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element skin="@shop_buy_button_gem_font1" skin.down="@shop_buy_button_gem_font1" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" model="#MOB001"/>
				</element>
			</element>

			<element anchorY="0" visible.gem-pixelcoin-inactive="false" visible.basic="true" skin="@btn_center1" skin.down="@btn_center2" preferredWidth="440" preferredHeight="142">
				<element anchorY="45" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="25"/></p:layout>
					<element skin="@shop_buy_icon_drevo_white" skin.down="@shop_buy_icon_drevo2" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element name="button_drevo_label" skin="@oswald_46_white_at" skin.down="@oswald_46_brown_at" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-5"/>
				</element>
			</element>

			<element anchorY="0" visible.gem-basic-pixelcoin="false" visible.inactive="true" skin="@shop_btn_inactive">
				<element anchorY="45" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="25"/></p:layout>
					<element skin="@shop_buy_icon_inactive" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element skin="@shop_buy_button_inactive_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" model="#MOB001"/>
				</element>
			</element>

			<element anchorY="0" visible.gem-basic-inactive="false" visible.pixelcoin="true" skin="@button_blue_01" skin.down="@button_blue_01" preferredWidth="440" preferredHeight="142">
				<element anchorY="30" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="25"/></p:layout>
					<element skin="@pixel_id_coin" skin.down="@pixel_id_coin" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element skin="@shop_buy_button_blue_font" skin.down="@shop_buy_button_blue_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" model="#MOB001"/>
				</element>
			</element>

		</element>


	</element>
</element>