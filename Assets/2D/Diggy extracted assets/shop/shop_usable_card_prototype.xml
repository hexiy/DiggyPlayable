			<element name="button" mouseChildren="false" skin.default="@btn_center1" skin.down="@btn_center2" preferredWidth="440" preferredHeight="142" skin.inactive="@shop_btn_inactive" pivotAlign="MIDDLE_CENTER" anchorY="0" anchorY.down="7" mouseOut="usableBuyOut_handler" mouseUp="usableBuyUp_handler" mouseDown="usableBuyDown_handler" mouseDown.inactive="" mouseUp.inactive="">
