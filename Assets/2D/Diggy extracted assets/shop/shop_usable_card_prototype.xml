					<element name="buttonIcon" skin="@shop_gem_icon1" skin.inactive="@shop_buy_icon_inactive" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element name="buttonLabel" skin="@shop_buy_button_gem_font1" skin.inactive="@shop_buy_button_inactive_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"/>
				</element>
			</element>

			<element name="buttonPixel" mouseChildren="false"
					 preferredWidth="440" preferredHeight="142"
					 pivotAlign="MIDDLE_CENTER"
					 anchorY="0"
					 anchorY.down="7"

					 skin="@button_blue_01"
					 skin.down="@button_blue_01"
					 skin.inactive="@shop_btn_inactive"

					 mouseOut="usableBuyOut_handler"
					 mouseUp="usableBuyUp_handler"
					 mouseDown="usableBuyDown_handler"
					 mouseDown.inactive=""
					 mouseUp.inactive=""
			>
				<element anchorY="30" anchorY.inactive="45" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="10"  gap.inactive="25"/></p:layout>
					<element name="buttonIcon"
							 skin="@pixel_id_coin"
							 skin.inactive="@shop_buy_icon_inactive"
							 anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"
							 anchorY="-15"/>
					<element name="buttonLabel"
							 skin="@shop_buy_button_blue_font"
							 skin.inactive="@shop_buy_button_inactive_font"
							 anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"
							 anchorY="0" anchorY.inactive="-5"/>
				</element>
			</element>

		</element>

	</element>
</element>