				<element name="region_badge"
						 skin.region1="@region_badge_1"
						 skin.region2="@region_badge_2"
						 skin.region3="@region_badge_3"
						 skin.region4="@region_badge_4"
						 skin.region5="@region_badge_5"
						 skin.region6="@region_badge_6"
						 skin.region7="@region_badge_7"
						 skin.region8="@region_badge_8"
						 skin.region9="@region_badge_9"
						 anchorLeft="0" anchorRight="1" anchorTop="0" anchorBottom="1"/>
			</element>

			<!-- VALUE -->
			<element skin="@shop_parameter_limit" anchorY="372" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
				<element anchorY="27" anchorX="-45" preferredWidth="200" preferredHeight="100" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<p:layout><horizontal gap="10"/></p:layout>
					<element name="type" skin="@ico_energy" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-10"/>
					<element name="value" skin="@shop_energy_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER"/>
				</element>
				<element anchorY="38" anchorX="160" preferredWidth="50" preferredHeight="50" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
					<element name="limitAmountValue" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" skin="@shop_limit_font"/>
					<element name="limitAmountNone" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" skin="@shop_no_limit" anchorY="-5"/>
				</element>
			</element>

			<!-- COST -->
			<element name="price" anchorX="30" anchorY="520" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorAlign.long_price="TOP_LEFT" pivotAlign.long_price="TOP_LEFT">
				<p:layout><horizontal gap="5"/></p:layout>
				<element name="priceImage" skin="@asset"/>
				<element name="priceValue" anchorY="15" skin="@shop_price_font"/>
				<element name="priceHave" anchorY="15" skin="@shop_price_have_font"/>
			</element>

			<!-- GEM COST -->
			<element name="gemPrice" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="515">
				<p:layout><horizontal gap="5"/></p:layout>
				<element name="gemImage" skin="@asset"/>
				<element name="gemValue" anchorY="28" skin="@shop_price_font"/>
			</element>

			<!-- LOCK -->
			<element name="lock" anchorLeft="0" anchorRight="1">
				<element skin="@shop_card_locked" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="570"/>
				<element name="lockText" skin="@shop_lock_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="500" preferredWidth="450" preferredHeight="400"/>
			</element>

		</element>

		<!-- LIMIT REACHED -->
		<element name="limitReached" anchorAlign="BOTTOM_CENTER" pivotAlign="BOTTOM_CENTER" anchorY="-30" skin="@shop_limit_reached">
