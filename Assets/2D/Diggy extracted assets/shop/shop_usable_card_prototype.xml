<element skin="@middle_popup" skin.pixel="@middle_popup_blue" preferredWidth="530" preferredHeight="956">
	<element anchorX="-20" preferredWidth="530" preferredHeight="926">
		<element name="name" skin="@shop_item_name_font" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER" anchorY="20" anchorX="0" anchorX.regionBadgeVisible="20"
				 preferredWidth="300" preferredHeight="200" flushBatch="true"/>

		<!-- SPECIAL WEEK DISCOUNT BADGE -->
		<element name="special_week_offer_discount" anchorAlign="TOP_RIGHT" pivotAlign="TOP_RIGHT" anchorY="60" skin="@special_week_discount_30" visible="false"/>
