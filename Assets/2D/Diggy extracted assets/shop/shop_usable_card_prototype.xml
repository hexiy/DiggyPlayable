					<element name="buttonIcon" skin="@shop_buy_icon_drevo_white" skin.inactive="@shop_buy_icon_inactive" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-15"/>
					<element name="buttonLabel" skin="@oswald_bold_85_basic_drevo1" skin.inactive="@shop_buy_button_inactive_font" anchorAlign="MIDDLE_CENTER" pivotAlign="MIDDLE_CENTER" anchorY="-5"/>
				</element>
			</element>

			<element name="buttonGem" mouseChildren="false" skin="@button_green_01" skin.down="@button_green_02" preferredWidth="440" preferredHeight="142" skin.inactive="@shop_btn_inactive" pivotAlign="MIDDLE_CENTER" anchorY="0" anchorY.down="7" mouseOut="usableBuyOut_handler" mouseUp="usableBuyUp_handler" mouseDown="usableBuyDown_handler" mouseDown.inactive="" mouseUp.inactive="">
				<element anchorX="-10" anchorY="30" preferredWidth="200" preferredHeight="160" anchorAlign="TOP_CENTER" pivotAlign="TOP_CENTER">
